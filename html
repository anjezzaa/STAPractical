<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>The Broken Guessing Game</title>
    <style>
        body { font-family: sans-serif; text-align: center; padding: 50px; }
        .container { border: 2px solid #000; padding: 20px; display: inline-block; }
        #message { font-weight: bold; color: blue; }
        input { width: 50px; padding: 5px; }
    </style>
</head>
<body>

    <div class="container">
        <h1>Number Guessing Game</h1>
        <p>I'm thinking of a number between 1 and 10...</p>
        
        <input type="number" id="guessInput">
        <button onclick="playGame()">Guess!</button>
        <button onclick="resetGame()">Restart</button>

        <p id="output"></p>
        <p>Attempts: <span id="attempts">0</span></p>
    </div>

    <script>
        // MISTAKE 1: Defining the secret number inside the function (it resets every click)
        // MISTAKE 2: Logic error in random range (Math.random * 10 can be 0)
        let count = 0;

        function playGame() {
            let secret = Math.floor(Math.random() * 10); 
            let userGuess = document.getElementById("guessInput").value;
            let display = document.getElementById("output");

            count = count + 1;
            document.getElementById("attempts").innerHTML = count;

            // MISTAKE 3: Using '==' on a string vs number (works, but bad practice)
            // MISTAKE 4: Missing curly braces on the first IF
            if (userGuess == secret)
                display.innerText = "You won! 🏆";
                alert("Winner!"); 

            else if (userGuess > secret) {
                display.innerText = "Too high!";
            } else (userGuess < secret) { 
                // MISTAKE 5: 'else' statements cannot have conditions
                display.innerText = "Too low!";
            }
        }

        function resetGame() {
            // MISTAKE 6: Trying to clear a variable that isn't global
            secret = Math.floor(Math.random() * 10) + 1;
            document.getElementById("output").innerText = "Game Reset!";
        }
    </script>

</body>
</html>
